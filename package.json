{
  "name": "react-example",
  "private": true,
  "version": "0.0.9",
  "type": "module",
  "scripts": {
    "dev:server": "npm run dev --prefix server",
    "dev:web": "vite --port=3007 --host=0.0.0.0",
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "postinstall": "npm install --prefix server",
    "build": "vite build --mode hostinger && npm run --prefix server build",
    "start": "node server/start.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "server-dev": "npm run dev --prefix server",
    "server-build": "npm run build --prefix server",
    "server-start": "npm run start --prefix server",
    "server-test": "npm run test-payment --prefix server",
    "seed-admin": "npm run seed-admin --prefix server",
    "db-migrate": "npm run prisma:migrate --prefix server",
    "migrate-from-firestore": "npm run migrate-from-firestore --prefix server",
    "build:archive": "node scripts/build-deploy-archive.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.6",
    "react-router": "^7.14.2",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.2.6"
  }
}
