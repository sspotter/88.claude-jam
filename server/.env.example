PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MySQL connection string (Prisma). The schema provider is `mysql`.
# Local dev points at your local MySQL; each deployment sets its own URL.
# Special characters in the password must be URL-encoded (e.g. @ -> %40).
# `npm run dev` auto-creates the database, syncs the schema, and seeds the admin.
DATABASE_URL="mysql://root:PASSWORD@127.0.0.1:3306/jamhawi_dev"

# Auth
JWT_SECRET=change-me-to-a-long-random-string
# Optional: seed the first admin via `npm run seed-admin`
SEED_ADMIN_EMAIL=admin@jamhawi.com
SEED_ADMIN_PASSWORD=change-me

# Uploads (product images stored on local disk, served at /uploads)
UPLOAD_DIR=uploads
# Public base URL the frontend uses to load uploaded images (defaults to server origin)
PUBLIC_BASE_URL=http://localhost:5000

# Paymob Credentials (Intention API)
# PUBLIC_KEY is combined with the intention's client_secret to build the Unified
# Checkout URL; SECRET_KEY authenticates the Create Intention call (as `Token <key>`).
PAYMOB_PUBLIC_KEY=egy_pk_xxxxxx
PAYMOB_SECRET_KEY=egy_sk_xxxxxx
PAYMOB_HMAC_SECRET=xxxxxx
PAYMOB_CARD_INTEGRATION_ID=xxxxxx
PAYMOB_WALLET_INTEGRATION_ID=xxxxxx
# Optional: a USD-enabled card integration, only used by the live payment-scenario
# test (npm run test-payment-live) to exercise a USD card charge.
# PAYMOB_CARD_INTEGRATION_ID_USD=xxxxxx
# Business phone for WhatsApp checkout updates
BUSINESS_PHONE=201027982033

# LibreTranslate (admin "auto-translate description" proxy). Defaults to a
# keyless public mirror if unset. Point at https://libretranslate.com/translate
# (or a self-hosted instance) and set the key once you have a paid/free API key.
# LIBRETRANSLATE_URL=https://translate.fedilab.app/translate
# LIBRETRANSLATE_API_KEY=

# --- Migration only (one-time Firestore -> Postgres import) ---
# Required only when running `npm run migrate-from-firestore`. Remove afterward.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
