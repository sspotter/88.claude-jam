PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jamhawi?schema=public"

# Auth
JWT_SECRET=change-me-to-a-long-random-string
# Optional: seed the first admin via `npm run seed-admin`
SEED_ADMIN_EMAIL=admin@jamhawi.com
SEED_ADMIN_PASSWORD=change-me

# Uploads (product images stored on local disk, served at /uploads)
UPLOAD_DIR=uploads
# Public base URL the frontend uses to load uploaded images (defaults to server origin)
PUBLIC_BASE_URL=http://localhost:5000

# Paymob Credentials
PAYMOB_SECRET_KEY=sk_live_xxxxxx
PAYMOB_HMAC_SECRET=xxxxxx
PAYMOB_CARD_INTEGRATION_ID=xxxxxx
PAYMOB_WALLET_INTEGRATION_ID=xxxxxx
# Business phone for WhatsApp checkout updates
BUSINESS_PHONE=201027982033

# --- Migration only (one-time Firestore -> Postgres import) ---
# Required only when running `npm run migrate-from-firestore`. Remove afterward.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
